#
# Environment variables example.
#

# Flask Configuration
# FLASK_ENV=development # Is set in Docerfile

# Database
DATABASE_USERNAME=
DATABASE_HOST=

# Secrets (should be in /run/secrets in Docker Swarm or environment)
# These are read via read_secret() function which checks /run/secrets/ first,
# then falls back to environment variables:
# FLASK_SECRET_KEY=your-secret-key-here
# DBA_PASSWORD=database-password
# TELEGRAM_TOKEN=your-telegram-token
# PRISJAKT_CLIENT_SECRET=prisjakt-secret
# OPENAI_TOKEN=openai-api-key
# TELEGRAM_TOKEN=telegram-token  

# Prisjakt API Configuration
PRISJAKT_CLIENT_ID=

# WebAuthn Configuration
WEBAUTHN_RP_ID=                   # Relying Party ID (domain)
WEBAUTHN_ORIGIN=                  # Origin URL
WEBAUTHN_RP_NAME=Gavmild          # Human-readable name
WEBAUTHN_RP_ID_DEV=localhost
WEBAUTHN_ORIGIN_DEV=http://localhost:5005
WEBAUTHN_RP_NAME_DEV=Gavmild Local
# Telegram Bot Configuration
TELEGRAM_GROUP_ID=                  # Telegram group/channel ID
TELEGRAM_ADMIN_ID=           # Telegram user ID for admin

# Note: For production:
# 1. Set FLASK_ENV=production
# 2. Use strong FLASK_SECRET_KEY
# 3. Use HTTPS (WEBAUTHN_ORIGIN must be https://)
# 4. Set secure cookies: SESSION_COOKIE_SECURE=True
# 5. Never set DEBUG=True
